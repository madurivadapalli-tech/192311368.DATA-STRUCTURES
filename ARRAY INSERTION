#include <stdio.h>

int main()
{
    int a[100], n, pos, ele, i;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    printf("Enter array elements:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &a[i]);

    printf("Enter position to insert: ");
    scanf("%d", &pos);

    printf("Enter element to insert: ");
    scanf("%d", &ele);

    for(i = n; i >= pos; i--)
        a[i] = a[i - 1];

    a[pos - 1] = ele;
    n++;

    printf("Array after insertion:\n");

    for(i = 0; i < n; i++)
        printf("%d ", a[i]);

    return 0;
}
