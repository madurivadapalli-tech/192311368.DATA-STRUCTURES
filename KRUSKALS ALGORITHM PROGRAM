#include <stdio.h>

#define MAX 10

struct Edge {
    int u, v, w;
};

int parent[MAX];

int find(int i) {
    while (parent[i] != i)
        i = parent[i];
    return i;
}

void unionSet(int a, int b) {
    parent[a] = b;
}

void kruskal(struct Edge edges[], int e, int v) {
    int minCost = 0;

    for (int i = 0; i < v; i++)
        parent[i] = i;

    printf("Edges in Minimum Spanning Tree:\n");

    for (int i = 0; i < e; i++) {
        int a = find(edges[i].u);
        int b = find(edges[i].v);

        if (a != b) {
            printf("%d -- %d = %d\n",
                   edges[i].u, edges[i].v, edges[i].w);
            minCost += edges[i].w;
            unionSet(a, b);
        }
    }

    printf("Minimum Cost = %d\n", minCost);
}

int main() {
    int v = 4, e = 5;

    struct Edge edges[] = {
        {0, 1, 10},
        {2, 3, 4},
        {0, 3, 5},
        {0, 2, 6},
        {1, 3, 15}
    };

    /* Sort edges by weight */
    for (int i = 0; i < e - 1; i++) {
        for (int j = 0; j < e - i - 1; j++) {
            if (edges[j].w > edges[j + 1].w) {
                struct Edge temp = edges[j];
                edges[j] = edges[j + 1];
                edges[j + 1] = temp;
            }
        }
    }

    kruskal(edges, e, v);

    return 0;
}
