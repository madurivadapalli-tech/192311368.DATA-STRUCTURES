#include <stdio.h>

#define MAX 10

int pq[MAX];
int size = 0;

void insert(int value) {
    int i = size - 1;

    while (i >= 0 && pq[i] < value) {
        pq[i + 1] = pq[i];
        i--;
    }

    pq[i + 1] = value;
    size++;
}

void deleteHighest() {
    if (size == 0) {
        printf("Priority Queue is Empty\n");
        return;
    }

    printf("Deleted Element: %d\n", pq[0]);

    for (int i = 0; i < size - 1; i++)
        pq[i] = pq[i + 1];

    size--;
}

void display() {
    if (size == 0) {
        printf("Priority Queue is Empty\n");
        return;
    }

    printf("Priority Queue: ");
    for (int i = 0; i < size; i++)
        printf("%d ", pq[i]);

    printf("\n");
}

int main() {
    insert(30);
    insert(10);
    insert(50);
    insert(20);

    display();

    deleteHighest();

    display();

    return 0;
}
